#include<iostream>
#include<vector>
#include<algorithm>
using namespace std;
void bucketSort(vector<double>& a,int n)
{
	if (n <= 0) return;
	vector<vector<double>>buckets(n);
	for (int i = 0; i < n; i++)
	{
		double idx = a[i] * n;
		buckets[idx].push_back(a[i]);
	}
	for (int i = 0; i < n; i++)
	{
		sort(buckets[i].begin(), buckets[i].end());
	}
	int index = 0;
	for (int i = 0; i < n; i++)
	{
		for (double num : buckets[i]) a[index++] = num;
	}
}
int main()
{
	int n;
	cin >> n;
	vector<double>a(n);
	for (int i = 0; i < n; i++) cin >> a[i];
	bucketSort(a, n);
	for (int i = 0; i < n; i++) cout << a[i] << ' ';
	return 0;
}
