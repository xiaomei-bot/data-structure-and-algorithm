#include<iostream>
using namespace std;
void SelectSort(int a[], int n)
{
	for (int i = 0; i < n - 1; i++)
	{
		for (int j = i + 1; j < n; j++)
		{
			if (a[j] < a[i])
			{
				int temp = a[i];
				a[i] = a[j];
				a[j] = temp;
			}
		}
	}
	return;
}
int main()
{
	int n;
	cin >> n;
	int* a = new int[n];
	for (int i = 0; i < n; i++) cin >> a[i];
	SelectSort(a, n);
	for (int i = 0; i < n;i++) cout << a[i] << ' ';
	delete[] a;
	return 0;
}
