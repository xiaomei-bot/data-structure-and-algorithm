#include<iostream>
using namespace std;
void HeapAdjust(int a[], int i,int n)
{
	int temp = a[i];
	for (int j = 2 * i; j <= n; j *= 2)
	{
		if (j<n&&a[j] < a[j + 1]) j++;
		if (temp >= a[j]) break;
		a[i] = a[j];
		i = j;
	}
	a[i] = temp;
}
void HeapSort(int a[], int n)
{
	for (int i = n / 2; i >= 1; i--)
	{
		HeapAdjust(a, i, n);
	}
	for (int i = n; i > 1; i--)
	{
		swap(a[1], a[i]);
		HeapAdjust(a, 1, i - 1);
	}
}
int main()
{
	int n;
	cin >> n;
	int* a = new int[n + 1];
	for (int i = 1; i <= n; i++) cin >> a[i];
	HeapSort(a, n);
	for (int i = 1; i <= n; i++) cout << a[i] << ' ';
	delete[]a;
	return 0;
}
